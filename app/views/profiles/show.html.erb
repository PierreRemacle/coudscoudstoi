<div style="text-align:center;max-width:700px;padding:24px;">
  <h1 style="font-size:28px;font-weight:700;color:#1b1b24;margin:0 0 8px;">Qui coud aujourd'hui ?</h1>
  <p style="color:#9a9aa8;font-size:15px;margin:0 0 48px;">Choisissez votre profil</p>

  <% if alert.present? %>
    <div style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;padding:10px 14px;border-radius:8px;margin-bottom:24px;font-size:13px;"><%= alert %></div>
  <% end %>

  <div style="display:flex;gap:20px;justify-content:center;flex-wrap:wrap;align-items:flex-start;">

    <%# Existing profiles %>
    <% @profiles.each do |profile| %>
      <%= form_with url: profile_path, method: :patch, style: "display:inline;" do |f| %>
        <%= f.hidden_field :name, value: profile.nom %>
        <button type="submit" style="background:#fff;border:2px solid #e8e8f0;border-radius:16px;padding:32px 28px;cursor:pointer;transition:border-color .15s,box-shadow .15s;width:140px;font-family:inherit;" onmouseover="this.style.borderColor='#5b50e3';this.style.boxShadow='0 4px 16px rgba(91,80,227,.15)'" onmouseout="this.style.borderColor='#e8e8f0';this.style.boxShadow='none'">
          <div style="width:64px;height:64px;border-radius:50%;background:#5b50e3;color:#fff;font-size:26px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;"><%= profile.nom.first.upcase %></div>
          <div style="font-size:15px;font-weight:600;color:#1b1b24;"><%= profile.nom %></div>
        </button>
      <% end %>
    <% end %>

    <%# Add new profile card %>
    <div style="width:140px;">
      <% if @new_profile.errors.any? %>
        <div style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;padding:8px 10px;border-radius:8px;font-size:12px;margin-bottom:8px;text-align:left;">
          <%= @new_profile.errors.full_messages.to_sentence %>
        </div>
      <% end %>
      <%= form_with model: @new_profile, url: profile_path, method: :post do |f| %>
        <div style="background:#fff;border:2px dashed #c8c8d8;border-radius:16px;padding:24px 16px;display:flex;flex-direction:column;align-items:center;gap:12px;">
          <div style="width:64px;height:64px;border-radius:50%;background:#f0f0f5;color:#9a9aa8;font-size:26px;display:flex;align-items:center;justify-content:center;">
            <i data-lucide="plus"></i>
          </div>
          <%= f.text_field :nom, placeholder: "Prénom", style: "width:100%;box-sizing:border-box;border:1px solid #e8e8f0;border-radius:8px;padding:8px 10px;font-size:13px;font-family:inherit;text-align:center;outline:none;", onfocus: "this.style.borderColor='#5b50e3'", onblur: "this.style.borderColor='#e8e8f0'" %>
          <%= f.submit "Ajouter", style: "width:100%;background:#5b50e3;color:#fff;border:none;border-radius:8px;padding:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
