<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Patrons de couture" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/svg+xml" href="/icon.svg">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "patrons", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app">
      <nav class="rail">
        <div class="rail-logo"><i data-lucide="scissors"></i></div>
        <%= link_to patrons_path, class: "rail-btn #{controller_name == 'patrons' && action_name == 'index' ? 'is-active' : ''}", title: "Bibliothèque" do %>
          <i data-lucide="library"></i>
        <% end %>
        <%= link_to new_patron_path, class: "rail-btn #{controller_name == 'patrons' && %w[new create].include?(action_name) ? 'is-active' : ''}", title: "Nouveau patron" do %>
          <i data-lucide="plus-square"></i>
        <% end %>
        <div class="rail-spacer">
          <%= link_to settings_path, class: "rail-btn #{controller_name == 'settings' ? 'is-active' : ''}", title: "Paramètres" do %>
            <i data-lucide="settings"></i>
          <% end %>
          <%= button_to session_path, method: :delete, class: "rail-btn", title: "Déconnexion", style: "background:none;border:none;cursor:pointer;" do %>
            <i data-lucide="log-out"></i>
          <% end %>
          <%= link_to manage_profile_path, class: "rail-avatar #{controller_name == 'profiles' && action_name == 'manage' ? 'is-active' : ''}", title: current_user, style: "text-decoration:none;" do %>
            <%= current_user&.first %>
          <% end %>
        </div>
      </nav>

      <main class="main">
        <% if notice.present? %>
          <div class="flash flash-notice"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="flash flash-alert"><%= alert %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => lucide.createIcons());
      document.addEventListener("turbo:render",     () => lucide.createIcons());
    </script>
  </body>
</html>
