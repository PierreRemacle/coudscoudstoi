<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Patrons de couture" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "patrons", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="background:var(--bg,#f5f5f8);min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:var(--font,'Plus Jakarta Sans',sans-serif);">
    <%= yield %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => lucide.createIcons());
      document.addEventListener("turbo:render",     () => lucide.createIcons());
    </script>
  </body>
</html>
