<%= form_with url: patrons_path, method: :get, class: "filters" do |f| %>
  <div class="filters-head">
    <b><i data-lucide="sliders-horizontal"></i>Filtres</b>
    <%= link_to "Réinitialiser", patrons_path, class: "link-accent" %>
  </div>

  <div class="filter-group">
    <div class="filter-label">Marque</div>
    <%= f.select :marque_id,
          options_from_collection_for_select(marques, :id, :nom, params[:marque_id]),
          { include_blank: "Toutes les marques" },
          class: "select #{params[:marque_id].blank? ? 'is-placeholder' : ''}" %>
  </div>

  <div class="filter-group">
    <div class="filter-label">Genre</div>
    <div class="chips" data-controller="multichip">
      <% Patron.genres.each_key do |g| %>
        <button type="button"
                class="chip <%= Array(params[:genre]).include?(g) ? 'is-active' : '' %>"
                data-action="click->multichip#toggleChip">
          <input type="checkbox" name="genre[]" value="<%= g %>"
                 style="display:none;"
                 <%= "checked" if Array(params[:genre]).include?(g) %>>
          <%= g.capitalize %>
        </button>
      <% end %>
    </div>
  </div>

  <div class="filter-group">
    <div class="filter-label">Vêtement</div>
    <div class="chips" style="flex-wrap:wrap;" data-controller="multichip">
      <% Patron::VETEMENTS.each do |v| %>
        <button type="button"
                class="chip <%= Array(params[:vetement]).include?(v) ? 'is-active' : '' %>"
                data-action="click->multichip#toggleChip">
          <input type="checkbox" name="vetement[]" value="<%= v %>"
                 style="display:none;"
                 <%= "checked" if Array(params[:vetement]).include?(v) %>>
          <%= v %>
        </button>
      <% end %>
    </div>
  </div>

  <div class="filter-group">
    <div class="filter-label">Matière</div>
    <div class="chips" style="flex-wrap:wrap;" data-controller="multichip">
      <% Patron::MATIERES.each do |m| %>
        <button type="button"
                class="chip <%= Array(params[:matiere]).include?(m) ? 'is-active' : '' %>"
                data-action="click->multichip#toggleChip">
          <input type="checkbox" name="matiere[]" value="<%= m %>"
                 style="display:none;"
                 <%= "checked" if Array(params[:matiere]).include?(m) %>>
          <%= m %>
        </button>
      <% end %>
    </div>
  </div>

  <div class="filter-group">
    <div class="filter-label">Difficulté</div>
    <div class="chips" data-controller="multichip">
      <% [["Facile", "facile"], ["Moyenne", "moyenne"], ["Difficile", "difficile"]].each do |label, val| %>
        <button type="button"
                class="chip <%= Array(params[:difficulte]).include?(val) ? 'is-active' : '' %>"
                data-action="click->multichip#toggleChip">
          <input type="checkbox" name="difficulte[]" value="<%= val %>"
                 style="display:none;"
                 <%= "checked" if Array(params[:difficulte]).include?(val) %>>
          <%= label %>
        </button>
      <% end %>
    </div>
  </div>

  <div class="filter-group">
    <div class="filter-label">Métrage (m)</div>
    <div class="row" style="gap:8px;align-items:center;">
      <%= f.number_field :metrage_min, value: params[:metrage_min], min: 0, max: 20, step: 0.5,
            class: "input", style: "width:68px;", placeholder: "min" %>
      <span style="font-size:12px;color:#9a9aa8;">–</span>
      <%= f.number_field :metrage_max, value: params[:metrage_max], min: 0, max: 20, step: 0.5,
            class: "input", style: "width:68px;", placeholder: "max" %>
      <span style="font-size:12px;color:#9a9aa8;">m</span>
    </div>
  </div>

  <div class="filter-group">
    <div class="filter-label">Ajouté entre</div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      <%= f.date_field :depuis,   value: params[:depuis],   class: "input", style: "font-size:12px;" %>
      <%= f.date_field :jusqu_au, value: params[:jusqu_au], class: "input", style: "font-size:12px;" %>
    </div>
  </div>

  <%= f.hidden_field :q, value: params[:q] %>
  <%= f.submit "Filtrer", class: "btn btn-primary", style: "width:100%;justify-content:center;margin-top:8px;" %>
<% end %>
